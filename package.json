{
  "name": "@ajmarquez99/discord-cli",
  "version": "0.3.1",
  "type": "module",
  "description": "Discord CLI for coding agents — post, read, react, reply, and manage threads via the Discord REST API, with a fail-closed channel allowlist. Ships an MCP server too.",
  "bin": {
    "discord": "./bin/discord.js",
    "discord-mcp": "./bin/discord-mcp.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Alejandro Marquez",
  "repository": {
    "type": "git",
    "url": "https://github.com/AJMarquez99/discord-cli.git"
  },
  "homepage": "https://github.com/AJMarquez99/discord-cli#readme",
  "bugs": {
    "url": "https://github.com/AJMarquez99/discord-cli/issues"
  },
  "keywords": [
    "discord",
    "cli",
    "bot",
    "allowlist",
    "mcp",
    "agentic"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "prepublishOnly": "npm run test:run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.13.0",
    "vitest": "^4.1.8"
  }
}
